{% extends 'base.html.twig' %}

{% block title %}Detalle del Proveedor{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-8">

        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">{{ proveedor.nombre }}</h5>
                {% if proveedor.activo %}
                    <span class="badge bg-success">Activo</span>
                {% else %}
                    <span class="badge bg-danger">Inactivo</span>
                {% endif %}
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Nombre</dt>
                    <dd class="col-sm-8">{{ proveedor.nombre }}</dd>

                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">{{ proveedor.email }}</dd>

                    <dt class="col-sm-4">Teléfono</dt>
                    <dd class="col-sm-8">{{ proveedor.telefono }}</dd>

                    <dt class="col-sm-4">Tipo</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-secondary">{{ proveedor.tipo }}</span>
                    </dd>

                    <dt class="col-sm-4">Estado</dt>
                    <dd class="col-sm-8">
                        {% if proveedor.activo %}
                            <span class="badge bg-success">Activo</span>
                        {% else %}
                            <span class="badge bg-danger">Inactivo</span>
                        {% endif %}
                    </dd>

                    <dt class="col-sm-4">Creado el</dt>
                    <dd class="col-sm-8">
                        {{ proveedor.createAt ? proveedor.createAt|date('d/m/Y H:i') : 'No disponible' }}
                    </dd>

                    <dt class="col-sm-4">Última actualización</dt>
                    <dd class="col-sm-8">
                        {{ proveedor.updateAt ? proveedor.updateAt|date('d/m/Y H:i') : 'No actualizado' }}
                    </dd>
                </dl>
            </div>
            <div class="card-footer d-flex gap-2">
                <a href="{{ path('app_proveedor_index') }}" class="btn btn-secondary">← Volver</a>
                <a href="{{ path('app_proveedor_edit', {id: proveedor.id}) }}" class="btn btn-warning">Editar</a>
            </div>
        </div>

    </div>
</div>
{% endblock %}