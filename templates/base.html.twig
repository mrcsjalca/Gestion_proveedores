<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Gestión de Proveedores{% endblock %}</title>
        
        <!-- Bootstrap 5 CSS -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <!-- Bootstrap Icons -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">

        {% block stylesheets %}{% endblock %}
    </head>
    <body class="bg-light">

        <!-- Navbar -->
        <nav class="navbar navbar-dark bg-dark mb-4">
            <div class="container">
                <a class="navbar-brand" href="{{ path('app_proveedor_index') }}">
                    Gestión de Proveedores
                </a>
                <div class="d-flex align-items-center gap-3">
                    {% if app.user %}
                        <a href="{{ path('app_proveedor_new') }}" class="btn btn-success btn-sm">+ Nuevo Proveedor</a>
                        <span class="text-white">{{ app.user.userIdentifier }}</span>
                        <a href="{{ logout_path() }}" class="btn btn-outline-light btn-sm">Cerrar sesión</a>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="btn btn-outline-light btn-sm">Iniciar sesión</a>
                        <a href="{{ path('app_register') }}" class="btn btn-success btn-sm">Registrarse</a>
                    {% endif %}
                </div>
            </div>
        </nav>

        <!-- Mensajes Flash -->
        <div class="container">
            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        </div>

        <!-- Contenido principal -->
        <div class="container">
            {% block body %}{% endblock %}
        </div>

        <!-- Bootstrap 5 JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>